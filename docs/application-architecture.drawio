  <diagram id="api-data-map" name="API Data Map">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="map_title" value="MCP Tools, REST Endpoints, and BigQuery Views" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1300" height="40" as="geometry"/></mxCell>
        <mxCell id="mcp_tools" value="&lt;b&gt;MCP tools/list&lt;/b&gt;&lt;br&gt;search_products&lt;br&gt;get_product_details&lt;br&gt;compare_products&lt;br&gt;get_category_margin_summary&lt;br&gt;estimate_cart&lt;br&gt;get_low_stock_best_sellers&lt;br&gt;get_financing_options&lt;br&gt;get_card_offers&lt;br&gt;get_installment_plans&lt;br&gt;get_loyalty_program_details&lt;br&gt;get_active_promotions&lt;br&gt;get_shipping_info&lt;br&gt;get_returns_policy&lt;br&gt;get_warranty_info&lt;br&gt;get_checkout_guidance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="40" y="110" width="360" height="460" as="geometry"/></mxCell>
        <mxCell id="endpoint_map" value="&lt;b&gt;Tool -&gt; REST endpoint -&gt; primary view&lt;/b&gt;&lt;br&gt;search_products -&gt; GET /products -&gt; vw_product_listing_current&lt;br&gt;get_product_details -&gt; GET /products/{product_id} -&gt; vw_product_detail_current&lt;br&gt;compare_products -&gt; POST /compare -&gt; vw_product_catalog_current&lt;br&gt;get_category_margin_summary -&gt; GET /categories -&gt; vw_category_navigation + vw_category_margin_summary&lt;br&gt;estimate_cart -&gt; POST /cart/estimate -&gt; vw_cart_pricing_current + financing/policy views&lt;br&gt;get_low_stock_best_sellers -&gt; GET /low-stock -&gt; vw_low_stock_best_sellers&lt;br&gt;get_financing_options -&gt; GET /financing -&gt; vw_active_financing_options&lt;br&gt;get_card_offers -&gt; GET /card-offers -&gt; vw_active_financing_options where option_type=CARD&lt;br&gt;get_installment_plans -&gt; GET /installment-plans -&gt; vw_active_financing_options where option_type=INSTALLMENT&lt;br&gt;get_loyalty_program_details -&gt; GET /loyalty -&gt; vw_loyalty_benefits&lt;br&gt;get_active_promotions -&gt; GET /promotions -&gt; vw_active_promotions&lt;br&gt;get_shipping_info -&gt; GET /shipping -&gt; vw_purchase_support_policies where policy_type=SHIPPING&lt;br&gt;get_returns_policy -&gt; GET /returns -&gt; vw_purchase_support_policies where policy_type=RETURN&lt;br&gt;get_warranty_info -&gt; GET /warranties -&gt; vw_purchase_support_policies where policy_type=WARRANTY&lt;br&gt;get_checkout_guidance -&gt; GET /checkout-guidance -&gt; vw_checkout_support" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#F97316;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="470" y="110" width="720" height="700" as="geometry"/></mxCell>
        <mxCell id="views" value="&lt;b&gt;BigQuery views&lt;/b&gt;&lt;br&gt;dataset: golf_products&lt;br&gt;&lt;br&gt;vw_product_catalog_current&lt;br&gt;vw_product_listing_current&lt;br&gt;vw_product_detail_current&lt;br&gt;vw_product_facets&lt;br&gt;vw_category_navigation&lt;br&gt;vw_cart_pricing_current&lt;br&gt;vw_low_stock_best_sellers&lt;br&gt;vw_category_margin_summary&lt;br&gt;vw_active_financing_options&lt;br&gt;vw_loyalty_benefits&lt;br&gt;vw_active_promotions&lt;br&gt;vw_purchase_support_policies&lt;br&gt;vw_checkout_support" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="1260" y="110" width="350" height="420" as="geometry"/></mxCell>
        <mxCell id="tables" value="&lt;b&gt;Seeded tables&lt;/b&gt;&lt;br&gt;dim_brands, dim_suppliers, dim_categories, dim_products, dim_product_variants&lt;br&gt;fact_product_reviews, fact_inventory_snapshots, fact_price_history, fact_sales_order_lines, fact_product_performance_90d&lt;br&gt;dim_payment_methods, dim_card_offers, dim_installment_plan_offers&lt;br&gt;dim_loyalty_programs, dim_loyalty_tiers, dim_promotions&lt;br&gt;dim_shipping_services, dim_return_policies, dim_warranty_policies, dim_checkout_guidance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="1260" y="590" width="620" height="220" as="geometry"/></mxCell>
        <mxCell id="seed" value="&lt;b&gt;Seed source&lt;/b&gt;&lt;br&gt;data/bigquery/golf_store_option_b_bigquery_fixed.sql&lt;br&gt;Terraform renders project, dataset, location and runs bq query via terraform_data.seed_golf_products." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="1260" y="860" width="620" height="110" as="geometry"/></mxCell>
        <mxCell id="me1" value="tools/call" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#CA8A04;fontSize=11;" edge="1" parent="1" source="mcp_tools" target="endpoint_map"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="me2" value="Product API queries views" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#2563EB;fontSize=11;" edge="1" parent="1" source="endpoint_map" target="views"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="me3" value="views derive from tables" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#4F46E5;fontSize=11;" edge="1" parent="1" source="tables" target="views"><mxGeometry relative="1" as="geometry"/></mxCell>
