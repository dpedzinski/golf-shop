<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="runtime-architecture" name="Runtime Architecture">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2300" pageHeight="1350" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Fairway Supply / GECX Golf Store - Runtime Architecture" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="summary" value="Canonical deployed path: customer browser -&gt; Cloud Run storefront -&gt; CES WEB_UI deployment -&gt; root agent -&gt; MCP toolset -&gt; MCP Cloud Function -&gt; Product REST API Cloud Function -&gt; BigQuery views." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;fontSize=12;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1550" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="browser" value="&lt;b&gt;Customer Browser&lt;/b&gt;&lt;br&gt;Public shopper session&lt;br&gt;Loads storefront, chat, and direct API clients" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=12;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="230" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="cloudrun" value="&lt;b&gt;Cloud Run Storefront&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_cloud_run_v2_service.static_site&lt;/b&gt;&lt;br&gt;service: golf-store-static-site&lt;br&gt;source: apps/static-site&lt;br&gt;runtime: Vinext / Next / React&lt;br&gt;service account: golf-static-site&lt;br&gt;invoker: allUsers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="170" width="350" height="185" as="geometry"/>
        </mxCell>
        <mxCell id="runtime" value="&lt;b&gt;Storefront Browser Runtime&lt;/b&gt;&lt;br&gt;routes: /, /shop, /category/[slug], /products/[productId], /cart, /checkout, /compare&lt;br&gt;config: apps/static-site/app/storefront-config.ts&lt;br&gt;env: VITE_PRODUCT_API_URL, VITE_MCP_SERVER_URL, VITE_GECX_*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDFA;strokeColor=#0D9488;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="430" width="350" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="sdk" value="&lt;b&gt;Browser SDK&lt;/b&gt;&lt;br&gt;&lt;b&gt;@bread-prototype/gecx-sdk&lt;/b&gt;&lt;br&gt;ProductApiClient&lt;br&gt;McpClient&lt;br&gt;CesClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="170" width="300" height="165" as="geometry"/>
        </mxCell>
        <mxCell id="components" value="&lt;b&gt;Storefront UI Widgets&lt;/b&gt;&lt;br&gt;&lt;b&gt;@bread-prototype/gecx-components&lt;/b&gt;&lt;br&gt;product-list&lt;br&gt;product-comparison&lt;br&gt;financing-options&lt;br&gt;loyalty-tiers&lt;br&gt;Dialogflow CX rich content widgets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="400" width="300" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="cesapi" value="&lt;b&gt;CES Public API&lt;/b&gt;&lt;br&gt;https://ces.googleapis.com/v1&lt;br&gt;generateChatToken&lt;br&gt;runSession&lt;br&gt;session path: projects/PROJECT_ID/locations/us/apps/golf-store-customer-service/sessions/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9333EA;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1130" y="130" width="360" height="165" as="geometry"/>
        </mxCell>
        <mxCell id="deployment" value="&lt;b&gt;CES WEB_UI Deployment&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_ces_deployment.web&lt;/b&gt;&lt;br&gt;display: Golf Store Web&lt;br&gt;channel: WEB_UI / CHAT_ONLY&lt;br&gt;app version: web-v1&lt;br&gt;public access: enabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9333EA;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1130" y="345" width="360" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="agent" value="&lt;b&gt;CES App + Root Agent&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_ces_app.golf_store&lt;/b&gt;&lt;br&gt;app_id: golf-store-customer-service&lt;br&gt;display: Golf Store Customer Service&lt;br&gt;&lt;b&gt;google_ces_agent.golf_store_assistant&lt;/b&gt;&lt;br&gt;agent_id: golf-store-assistant&lt;br&gt;display: Golf Store Assistant&lt;br&gt;model: gemini-3.0-flash-001&lt;br&gt;temperature: 0.4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAE8FF;strokeColor=#A21CAF;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1130" y="555" width="360" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="toolset" value="&lt;b&gt;MCP Toolset&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_ces_toolset.golf_store_mcp&lt;/b&gt;&lt;br&gt;toolset_id: golf-store-bigquery-mcp&lt;br&gt;display: Golf Store BigQuery MCP&lt;br&gt;server address: golf-store-mcp-server /mcp/&lt;br&gt;auth: public by default; service-agent ID token when locked down" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1570" y="555" width="350" height="185" as="geometry"/>
        </mxCell>
        <mxCell id="mcp" value="&lt;b&gt;MCP Cloud Function Gen 2&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_cloudfunctions2_function.mcp_server&lt;/b&gt;&lt;br&gt;name: golf-store-mcp-server&lt;br&gt;entry point: handle_request&lt;br&gt;endpoint: /mcp&lt;br&gt;serverInfo.name: golf-store-bigquery-mcp&lt;br&gt;methods: initialize, tools/list, tools/call&lt;br&gt;service account: golf-mcp-server&lt;br&gt;env: PRODUCT_API_BASE_URL, PRODUCT_API_AUDIENCE, PRODUCT_API_AUTH_MODE, ALLOWED_ORIGINS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1980" y="430" width="300" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="api" value="&lt;b&gt;Product REST API Cloud Function Gen 2&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_cloudfunctions2_function.product_api&lt;/b&gt;&lt;br&gt;name: golf-store-product-api&lt;br&gt;entry point: handle_request&lt;br&gt;service account: golf-product-api&lt;br&gt;endpoints: /products, /products/{id}, /compare, /categories, /facets, /cart/estimate, /low-stock, /financing, /card-offers, /installment-plans, /loyalty, /promotions, /shipping, /returns, /warranties, /checkout-guidance&lt;br&gt;env: BIGQUERY_PROJECT, BIGQUERY_DATASET, ALLOWED_ORIGINS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#F97316;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1980" y="790" width="300" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="bq" value="&lt;b&gt;BigQuery Warehouse&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_bigquery_dataset.golf_products&lt;/b&gt;&lt;br&gt;dataset_id: golf_products&lt;br&gt;location: US&lt;br&gt;seed job: terraform_data.seed_golf_products&lt;br&gt;SQL: data/bigquery/golf_store_option_b_bigquery_fixed.sql&lt;br&gt;views: vw_product_listing_current, vw_product_detail_current, vw_cart_pricing_current, vw_active_financing_options, vw_purchase_support_policies, vw_checkout_support" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1570" y="855" width="350" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="assets" value="&lt;b&gt;GECX Exported Assets&lt;/b&gt;&lt;br&gt;instruction: gecx/agents/golf-store-assistant/instruction.txt&lt;br&gt;skills: product-advice, offers-and-financing, loyalty-and-promotions, purchase-support, storefront-rich-content&lt;br&gt;guardrails: Default Safety Guardrail, Default Prompt Guardrail&lt;br&gt;evaluations: search, details, compare, shipping scenarios" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF2F8;strokeColor=#DB2777;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="690" width="300" height="220" as="geometry"/>
        </mxCell>          <mxGeometry x="750" y="970" width="300" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="pytools" value="&lt;b&gt;Direct CES Python Tools&lt;/b&gt;&lt;br&gt;&lt;b&gt;google_ces_tool.python&lt;/b&gt;&lt;br&gt;search_products, get_product_details, compare_products, get_checkout_guidance, get_shipping_info, get_returns_policy, get_warranty_info, get_financing_options, get_loyalty_program_details&lt;br&gt;provisioned as demo/reference assets; root agent uses MCP path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=12;align=left;verticalAlign=top;spacing=10;dashed=1;" vertex="1" parent="1">
